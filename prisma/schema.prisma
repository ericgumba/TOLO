generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  FREE
  PAID
}

enum NodeLevel {
  SUBJECT
  TOPIC
  SUBTOPIC
}

enum ReviewStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
  STRUGGLING
}

enum LlmUsageType {
  GRADE
  HINT
  QUESTION_GENERATION
}

enum GeneratedQuestionCategory {
  EXPLAIN
  ANALYZE
  EVALUATE
  APPLY
  TEACH
}

enum CompareInteractionCategory {
  COMPARE
  PART_WHOLE
  DEPENDENCY
  ANALOGY
  TRADEOFF
  MECHANISM_LINK
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  passwordHash       String
  subscriptionStatus SubscriptionStatus @default(FREE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  nodes          Node[]
  concepts       Concept[]
  reviewStates   ReviewState[]
  llmUsageEvents LlmUsageEvent[]
  compareAttempts ConceptRelationshipAttempt[]
}

model Node {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?
  title     String
  level     NodeLevel
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Node?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Node[]    @relation("NodeChildren")
  concepts  Concept[]
  tags      Tag[]     @relation("SubjectTags")
  conceptRelationships ConceptRelationship[]

  @@index([userId])
  @@index([userId, parentId])
  @@index([userId, level])
}

model Concept {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String
  title     String   @map("body")
  score     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  node               Node              @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  reviewStates       ReviewState[]
  generatedQuestions GeneratedQuestion[]
  conceptTags        ConceptTag[]
  relationshipsAsFirst  ConceptRelationship[]      @relation("ConceptRelationshipFirst")
  relationshipsAsSecond ConceptRelationship[]      @relation("ConceptRelationshipSecond")

  @@index([userId, nodeId])
  @@index([nodeId])
}

model Tag {
  id             String       @id @default(cuid())
  subjectId      String
  name           String
  normalizedName String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subject     Node         @relation("SubjectTags", fields: [subjectId], references: [id], onDelete: Cascade)
  conceptTags ConceptTag[]

  @@unique([subjectId, normalizedName])
  @@index([subjectId])
}

model ConceptTag {
  conceptId String
  tagId     String

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conceptId, tagId])
  @@index([tagId])
}

model GeneratedQuestion {
  id         String                    @id @default(cuid())
  conceptId  String                    @map("questionId")
  category   GeneratedQuestionCategory
  body       String
  score      Int?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([conceptId, category], map: "GeneratedQuestion_questionId_category_key")
  @@index([conceptId], map: "GeneratedQuestion_questionId_idx")
}

model ConceptRelationship {
  id         String   @id @default(cuid())
  subjectId   String
  conceptAId  String
  conceptBId  String
  pairKey     String   @unique
  rationale   String?
  confidence  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject  Node    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  conceptA Concept @relation("ConceptRelationshipFirst", fields: [conceptAId], references: [id], onDelete: Cascade)
  conceptB Concept @relation("ConceptRelationshipSecond", fields: [conceptBId], references: [id], onDelete: Cascade)
  prompts  ConceptRelationshipPrompt[]
  attempts ConceptRelationshipAttempt[]

  @@index([subjectId])
  @@index([conceptAId])
  @@index([conceptBId])
  @@index([subjectId, conceptAId])
  @@index([subjectId, conceptBId])
}

model ConceptRelationshipPrompt {
  id             String                     @id @default(cuid())
  relationshipId String
  category       CompareInteractionCategory
  prompt         String
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  relationship ConceptRelationship       @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  attempts     ConceptRelationshipAttempt[]

  @@unique([relationshipId, category])
  @@index([relationshipId])
}

model ConceptRelationshipAttempt {
  id             String                     @id @default(cuid())
  userId         String
  relationshipId String
  promptId       String?
  category       CompareInteractionCategory
  prompt         String
  userAnswer     String
  llmScore       Int
  llmFeedback    String
  llmCorrection  String
  answeredAt     DateTime                   @default(now())
  createdAt      DateTime                   @default(now())

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relationship ConceptRelationship      @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  promptRef    ConceptRelationshipPrompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  @@index([userId, answeredAt])
  @@index([relationshipId, answeredAt])
  @@index([promptId])
}

model ReviewState {
  id              String       @id @default(cuid())
  userId          String
  conceptId       String       @map("questionId")
  status          ReviewStatus @default(NEW)
  intervalDays    Int          @default(1)
  repetitionCount Int          @default(0)
  lastAnsweredAt  DateTime?
  lastReviewedAt  DateTime?
  lastQuizAccessedAt DateTime?
  nextReviewAt    DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId], map: "ReviewState_userId_questionId_key")
  @@index([userId, nextReviewAt])
  @@index([userId, status])
}

model LlmUsageEvent {
  id        String       @id @default(cuid())
  userId    String
  type      LlmUsageType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}
