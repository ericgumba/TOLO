generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  FREE
  PAID
}

enum NodeLevel {
  SUBJECT
  TOPIC
  SUBTOPIC
}

enum ReviewStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
  STRUGGLING
}

enum LlmUsageType {
  GRADE
  HINT
  QUESTION_GENERATION
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  passwordHash       String
  subscriptionStatus SubscriptionStatus @default(FREE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  nodes         Node[]
  questions     Question[]
  reviewStates  ReviewState[]
  llmUsageEvents LlmUsageEvent[]
}

model Node {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?
  title     String
  level     NodeLevel
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Node?      @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Node[]     @relation("NodeChildren")
  questions Question[]

  @@index([userId])
  @@index([userId, parentId])
  @@index([userId, level])
}

model Question {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  node         Node              @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  reviewStates ReviewState[]

  @@index([userId, nodeId])
  @@index([nodeId])
}

model ReviewState {
  id              String       @id @default(cuid())
  userId          String
  questionId      String
  status          ReviewStatus @default(NEW)
  intervalDays    Int          @default(1)
  repetitionCount Int          @default(0)
  lastAnsweredAt  DateTime?
  lastReviewedAt  DateTime?
  lastQuizAccessedAt DateTime?
  nextReviewAt    DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
  @@index([userId, status])
}

model LlmUsageEvent {
  id        String       @id @default(cuid())
  userId    String
  type      LlmUsageType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}
